# Supabase Configuration
# Obtenha essas informações no Dashboard do Supabase: https://supabase.com/dashboard

NUXT_PUBLIC_SUPABASE_URL=sua_url_do_supabase_aqui
NUXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# Exemplo:
# NUXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
# NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
